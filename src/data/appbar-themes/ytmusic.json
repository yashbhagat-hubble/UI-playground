{
  "key": "ytmusic",
  "label": "YT Music",
  "sdkCssVariables": {
    "--sdk-appbar-bg": "#000000",
    "--sdk-appbar-bottom-border": "transparent",
    "--sdk-appbar-height": "52px",
    "--sdk-appbar-title-color": "#ffffff",
    "--sdk-appbar-title-size": "18px",
    "--sdk-appbar-title-line-height": "24px",
    "--sdk-appbar-title-weight": "600",
    "--sdk-appbar-title-tracking": "-0.18px",
    "--sdk-appbar-icon-color": "#ffffff",
    "--sdk-appbar-icon-gap": "16px",
    "--sdk-appbar-icon-inner-size": "24px",
    "--sdk-appbar-icon-bg": "transparent",
    "--sdk-appbar-icon-border": "transparent",
    "--sdk-appbar-icon-size": "24px",
    "--sdk-appbar-icon-radius": "0px"
  },
  "appbarConfig": {
    "backIcon": "caret",
    "titleAlign": "left"
  }
}
