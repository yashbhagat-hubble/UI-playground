{
  "key": "uber",
  "label": "Uber",
  "defaultIconStyle": "emoji",
  "fontImportUrl": "https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap",
  "telescopeCssVariables": {
    "--brand-tbd-base": "#5f259f",
    "--brand-tbd-dark": "#4a1a80",
    "--brand-tbd-light": "rgba(95, 37, 159, 0.18)",
    "--brand-tbd-lighter": "rgba(95, 37, 159, 0.08)",
    "--feature-base": "#7C3AED",
    "--feature-light": "rgba(124, 58, 237, 0.22)",
    "--feature-lighter": "rgba(124, 58, 237, 0.10)",
    "--brand-button-primary-text": "#FFFFFF",
    "--text-normal-primary": "#F5F5FF",
    "--text-normal-secondary": "#9898B8",
    "--text-normal-tertiary": "#5C5C7A",
    "--text-inverted-primary": "#0C0B18",
    "--background-normal-primary": "#0C0B18",
    "--background-normal-secondary": "#1C1B2C",
    "--background-normal-tertiary": "#262538",
    "--background-inverted-primary": "#F5F5FF",
    "--stroke-1": "#262538",
    "--stroke-2": "#36354A",
    "--stroke-3": "#4A4968",
    "--stroke-solid": "#7C3AED"
  },
  "sdkCssVariables": {
    "--font-family": "'DM Sans', system-ui, sans-serif",
    "--sdk-roundness-alpha": "12px",
    "--sdk-roundness-card": "12px",
    "--sdk-category-card-bg": "transparent",
    "--sdk-category-card-border": "transparent",
    "--sdk-category-card-icon-bg": "var(--background-normal-secondary)",
    "--sdk-category-card-icon-border": "var(--stroke-2)",
    "--sdk-category-card-icon-container-size": "56px",
    "--sdk-category-card-icon-container-radius": "12px",
    "--sdk-category-card-icon-color": "#FFFFFF",
    "--text-listing": "#7C3AED",
    "--text-listing-dark": "#5f259f",
    "--search-bg": "#1C1B2C",
    "--sdk-search-radius": "12px"
  }
}
