    "--sdk-category-card-icon-container-size": "56px",
    "--sdk-category-card-icon-container-radius": "9999px",
    "--sdk-category-card-icon-color": "var(--text-normal-primary)",
    "--text-listing": "#0D0D0D",
    "--text-listing-dark": "#000000",
    "--search-bg": "#F7F7F7",
    "--sdk-search-radius": "9999px"
  }
}
