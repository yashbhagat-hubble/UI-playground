{
  "key": "instamart",
  "label": "Instamart",
  "defaultIconStyle": "emoji",
  "fontImportUrl": "https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap",
  "telescopeCssVariables": {
    "--brand-tbd-base": "#1AA660",
    "--brand-tbd-dark": "#14854D",
    "--brand-tbd-light": "rgba(26, 166, 96, 0.15)",
    "--brand-tbd-lighter": "rgba(26, 166, 96, 0.07)",
    "--feature-base": "#1AA660",
    "--feature-light": "rgba(26, 166, 96, 0.18)",
    "--feature-lighter": "rgba(26, 166, 96, 0.08)",
    "--brand-button-primary-text": "#FFFFFF",
    "--text-normal-primary": "#1A1A1A",
    "--text-normal-secondary": "#555555",
    "--text-normal-tertiary": "#888888",
    "--text-inverted-primary": "#FFFFFF",
    "--background-normal-primary": "#FFFFFF",
    "--background-normal-secondary": "#DCE9F9",
    "--background-normal-tertiary": "#C6DAF5",
    "--background-inverted-primary": "#1A1A1A",
    "--stroke-1": "#E8EFF8",
    "--stroke-2": "#D0DFF0",
    "--stroke-3": "#AACAE8",
    "--stroke-solid": "#1AA660"
  },
  "sdkCssVariables": {
    "--font-family": "'Nunito', system-ui, sans-serif",
    "--sdk-roundness-alpha": "12px",
    "--sdk-roundness-card": "12px",
    "--sdk-category-card-bg": "var(--background-normal-secondary)",
    "--sdk-category-card-border": "transparent",
    "--sdk-category-card-icon-bg": "transparent",
    "--sdk-category-card-icon-border": "transparent",
    "--sdk-category-card-icon-container-size": "48px",
    "--sdk-category-card-icon-container-radius": "9999px",
    "--sdk-category-card-icon-color": "var(--text-normal-primary)",
    "--text-listing": "#1AA660",
    "--text-listing-dark": "#14854D",
    "--search-bg": "var(--background-normal-secondary)",
    "--sdk-search-radius": "12px"
  }
}
