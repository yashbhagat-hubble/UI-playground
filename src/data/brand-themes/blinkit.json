{
  "key": "blinkit",
  "label": "Blinkit",
  "defaultIconStyle": "emoji",
  "fontImportUrl": "https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap",
  "telescopeCssVariables": {
    "--brand-tbd-base": "#F8D03C",
    "--brand-tbd-dark": "#E0B800",
    "--brand-tbd-light": "rgba(248, 208, 60, 0.18)",
    "--brand-tbd-lighter": "rgba(248, 208, 60, 0.08)",
    "--feature-base": "#F8D03C",
    "--feature-light": "rgba(248, 208, 60, 0.18)",
    "--feature-lighter": "rgba(248, 208, 60, 0.08)",
    "--brand-button-primary-text": "#111214",
    "--text-normal-primary": "#FFFFFF",
    "--text-normal-secondary": "#A0A0A0",
    "--text-normal-tertiary": "#666666",
    "--text-inverted-primary": "#0D0D0D",
    "--background-normal-primary": "#111214",
    "--background-normal-secondary": "#222228",
    "--background-normal-tertiary": "#2E2E34",
    "--background-inverted-primary": "#FFFFFF",
    "--stroke-1": "#2E2E34",
    "--stroke-2": "#3A3A42",
    "--stroke-3": "#484850",
    "--stroke-solid": "#F8D03C"
  },
  "sdkCssVariables": {
    "--font-family": "'DM Sans', system-ui, sans-serif",
    "--sdk-roundness-alpha": "12px",
    "--sdk-roundness-card": "12px",
    "--sdk-category-card-bg": "transparent",
    "--sdk-category-card-border": "transparent",
    "--sdk-category-card-icon-bg": "var(--background-normal-secondary)",
    "--sdk-category-card-icon-border": "transparent",
    "--sdk-category-card-icon-container-size": "64px",
    "--sdk-category-card-icon-container-radius": "12px",
    "--sdk-category-card-icon-color": "var(--text-normal-primary)",
    "--text-listing": "#F8D03C",
    "--text-listing-dark": "#E0B800",
    "--search-bg": "var(--background-normal-secondary)",
    "--sdk-search-radius": "9999px"
  },
  "darkMode": true
}
